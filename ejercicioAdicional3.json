{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "pedidos": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "numero": { "type": "number" },
            "cliente": { "type": "string" },
            "total": {"type": "number", "minimum": 0 },

            "productos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "number" },
                  "nombre": { "type": "string" },
                  "precio": { "type": "number", "minimum": 0}
                },
                "required": ["id", "nombre", "precio"],
                "additionalProperties": false
              }
            }
          },
          "required": ["numero", "cliente", "total", "productos"],
          "additionalProperties": false
        }
      }
    },
    "required": ["pedidos"]
  }