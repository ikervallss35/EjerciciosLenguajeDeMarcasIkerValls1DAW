{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "cursos": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "codigo": { "type": "string" },
            "titulo": { "type": "string" },
            "modalidad": {
              "type": "string",
              "enum": ["online", "presencial"]
            },
            "alumnos": {"type": "number","minimum": 1}
          },
          "required": ["codigo", "titulo", "modalidad", "alumnos"],
          "additionalProperties": false
        }
      }
    },
    "required": ["cursos"]
  }